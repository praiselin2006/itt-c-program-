#include <stdio.h>
int main() {
float r, h, s, pi = 3.14159, three = 3.0;
int x, y, temp;
printf("Cone r, h, s:\n");
scanf("%f %f %f", &r, &h, &s);
printf("A: %f\nV: %f\n\n", pi * r * (r + s), (pi * r * r * h) / three);
printf("Enter 2 integers to swap:\n");
scanf("%d %d", &x, &y);temp = x;
x = y;
y = temp;
printf("Swapped: %d %d\n", x, y);
return 0;
}
