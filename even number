#include<stdio.h>
int main()
{
    int n,current = 0,max = 0;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++)
    {
        scanf("%d",&arr[i]);
        if(arr[i]%2==0)
        {
            current++;
            if(current>max)max=current;
        }
        else
        {
            current = 0;
        }
    }
    printf("%d",max);
    return 0;
}
